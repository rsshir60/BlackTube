<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/windowBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- App Logo and Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@mipmap/ic_launcher"
                android:layout_marginBottom="16dp"
                android:contentDescription="BlackTube Logo" />

            <org.schabi.newpipe.views.NewPipeTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BlackTube"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary" />

            <org.schabi.newpipe.views.NewPipeTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI-powered YouTube client"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:textColor="?attr/colorAccent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Version 1.0.0"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_ai_chip"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textColor="?android:attr/textColorSecondary" />
        </LinearLayout>

        <!-- Description -->
        <org.schabi.newpipe.views.NewPipeTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BlackTube is an open-source YouTube client focused on privacy, customization, and modern AI-powered features.\n\nBuilt with performance, simplicity, and user freedom in mind."
            android:textSize="15sp"
            android:lineSpacingExtra="6sp"
            android:gravity="center"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="32dp" />

        <!-- Developer Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@drawable/bg_ai_panel"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_ai_panel"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEVELOPER"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorAccent"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <org.schabi.newpipe.views.NewPipeTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ranjeet Shirsath"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:layout_marginBottom="16dp" />

                <!-- Social Links -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/about_instagram"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:text="Instagram"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:drawablePadding="16dp"
                        android:background="?attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/about_github"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:text="GitHub"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:drawablePadding="16dp"
                        android:background="?attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/about_linkedin"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:text="LinkedIn"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:drawablePadding="16dp"
                        android:background="?attr/selectableItemBackground" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="bottom|center_horizontal"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Made with ❤️ from India"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
