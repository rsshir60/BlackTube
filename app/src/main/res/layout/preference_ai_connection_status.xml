<?xml version="1.0" encoding="utf-8"?>
<!-- Connection status row for AI Provider section -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="API Status"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:id="@+id/tv_api_connection_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠ Not configured"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_test_connection"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:background="@drawable/bg_ai_chip"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:text="@string/ai_test_connection"
        android:textAllCaps="false"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="12sp" />

</LinearLayout>
