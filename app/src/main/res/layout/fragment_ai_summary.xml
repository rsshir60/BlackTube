<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/windowBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER CARD / TITLE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_stars"
                app:tint="?attr/colorAccent"
                android:layout_marginEnd="8dp" />

            <org.schabi.newpipe.views.NewPipeTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/summary_title"
                android:textAppearance="?android:attr/textAppearanceLarge"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>

        <!-- STATE LAYOUTS -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- CONFIGURATION NEEDED STATE -->
            <LinearLayout
                android:id="@+id/state_no_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_gravity="center"
                android:visibility="gone"
                tools:visibility="gone">

                <org.schabi.newpipe.views.NewPipeTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/gemini_not_configured"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary" />

                <Button
                    android:id="@+id/btn_open_settings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings"
                    style="?android:attr/borderlessButtonStyle"
                    android:textColor="?attr/colorAccent" />
            </LinearLayout>

            <!-- READY TO SUMMARIZE STATE -->
            <LinearLayout
                android:id="@+id/state_ready"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="top|center_horizontal"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="32dp"
                android:visibility="gone"
                tools:visibility="visible">

                <Button
                    android:id="@+id/btn_summarize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/summarize_button"
                    style="?android:attr/buttonStyle"
                    android:backgroundTint="?attr/colorAccent"
                    android:textColor="@android:color/white"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp" />
            </LinearLayout>

            <!-- LOADING STATE -->
            <LinearLayout
                android:id="@+id/state_loading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_gravity="center"
                android:visibility="gone"
                tools:visibility="gone">

                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:indeterminateTint="?attr/colorAccent"
                    android:layout_marginBottom="16dp" />

                <org.schabi.newpipe.views.NewPipeTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/summarizing"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary" />
            </LinearLayout>

            <!-- ERROR STATE -->
            <LinearLayout
                android:id="@+id/state_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_gravity="center"
                android:visibility="gone"
                tools:visibility="gone">

                <org.schabi.newpipe.views.NewPipeTextView
                    android:id="@+id/tv_error_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:textSize="14sp"
                    android:textColor="@android:color/holo_red_light"
                    tools:text="Failed to summarize: Network error" />

                <Button
                    android:id="@+id/btn_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/retry"
                    style="?android:attr/borderlessButtonStyle"
                    android:textColor="?attr/colorAccent" />
            </LinearLayout>

            <!-- SUCCESS STATE / RESULTS -->
            <LinearLayout
                android:id="@+id/state_success"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="gone">

                <!-- Summary Bullets Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <org.schabi.newpipe.views.NewPipeTextView
                            android:id="@+id/tv_summary_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:lineSpacingExtra="6sp"
                            android:textColor="?android:attr/textColorPrimary"
                            tools:text="• Bullet point number one.\n• Bullet point number two.\n• Bullet point number three." />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Re-summarize / Clear button -->
                <Button
                    android:id="@+id/btn_re_summarize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Refresh Summary"
                    style="?android:attr/borderlessButtonStyle"
                    android:textColor="?attr/colorAccent"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

        </FrameLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
