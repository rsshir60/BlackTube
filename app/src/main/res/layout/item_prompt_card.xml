<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_ai_panel"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top row: emoji + title + active badge + fav star -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <!-- Category emoji circle -->
            <TextView
                android:id="@+id/tv_prompt_emoji"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:textSize="18sp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_emoji_circle" />

            <!-- Title + chips -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_prompt_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="?android:attr/textColorPrimary" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:id="@+id/chip_default"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_bt_default_badge"
                        android:gravity="center"
                        android:minWidth="0dp"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:text="Default"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/chip_active"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_ai_chip_active"
                        android:gravity="center"
                        android:minWidth="0dp"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:text="Active"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/chip_builtin"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_ai_chip"
                        android:gravity="center"
                        android:minWidth="0dp"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:text="Built-in"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="10sp"
                        android:visibility="gone" />

                </LinearLayout>
            </LinearLayout>

            <!-- Favorite toggle -->
            <ImageButton
                android:id="@+id/btn_favorite"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_stars"
                android:contentDescription="Favorite"
                app:tint="?attr/colorAccent"
                android:alpha="0.3" />

        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/tv_prompt_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="?attr/colorAccent"
            android:layout_marginStart="46dp"
            android:layout_marginBottom="4dp"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/tv_prompt_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginStart="46dp"
            android:layout_marginBottom="10dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_prompt_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginStart="46dp"
            android:layout_marginBottom="12dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="46dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_use"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_bt_ai_action_button"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/prompt_library_use"
                android:textAllCaps="false"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_duplicate"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_ai_chip"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/prompt_library_duplicate"
                android:textAllCaps="false"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="12sp"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_edit"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_ai_chip"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/prompt_library_edit"
                android:textAllCaps="false"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="12sp"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_delete"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_ai_chip"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/prompt_library_delete"
                android:textAllCaps="false"
                android:textColor="#B71C1C"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
