<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:key="ai_features_preferences"
    android:title="@string/ai_features_title">

    <SwitchPreferenceCompat
        android:defaultValue="true"
        android:key="@string/gemini_enable_key"
        android:summary="@string/gemini_enable_summary"
        android:title="@string/gemini_enable_title" />

    <EditTextPreference
        android:key="@string/gemini_api_key_key"
        android:summary="@string/gemini_api_key_summary"
        android:title="@string/gemini_api_key_title"
        app:useSimpleSummaryProvider="true" />

    <Preference
        android:key="@string/import_ai_prompt_key"
        android:summary="@string/import_ai_prompt_summary"
        android:title="@string/import_ai_prompt_title" />

    <Preference
        android:key="@string/clear_ai_cache_key"
        android:summary="@string/clear_ai_cache_summary"
        android:title="@string/clear_ai_cache_title" />

</PreferenceScreen>
